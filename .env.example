# Open RAG MCP local configuration

# Application environment: development, test, or production
APP_ENV=development
SECRET_KEY=change-this-development-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTO_CREATE_TABLES=false
CORS_ORIGINS=http://localhost:9000,http://127.0.0.1:9000,http://localhost:9001,http://127.0.0.1:9001,http://YOUR_SERVER_IP:9000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Accept,Authorization,Content-Type,Last-Event-ID,Mcp-Session-Id,MCP-Protocol-Version,mcp-session-id,mcp-protocol-version
CORS_EXPOSE_HEADERS=Mcp-Session-Id,MCP-Session-Id,mcp-session-id,WWW-Authenticate
CORS_MAX_AGE=600
MCP_ISSUER_URL=http://127.0.0.1:8000
MCP_RESOURCE_SERVER_URL=http://127.0.0.1:8000/mcp
MCP_ENABLE_DNS_REBINDING_PROTECTION=true
MCP_ALLOWED_HOSTS=127.0.0.1:8000,localhost:8000,YOUR_SERVER_IP:8000
MCP_ALLOWED_ORIGINS=

# Relational application database provider: sqlite or postgresql
APP_DATABASE_PROVIDER=sqlite
DATABASE_URL=sqlite:///./data/open_rag_mcp.db

# Vector store provider: chroma, postgresql, or sqlite
VECTOR_STORE_PROVIDER=chroma

# ChromaDB settings used when VECTOR_STORE_PROVIDER=chroma
CHROMA_PERSIST_DIRECTORY=./data/chroma
CHROMA_COLLECTION_NAME=open_rag_documents

# PostgreSQL/pgvector settings used when VECTOR_STORE_PROVIDER=postgresql
PGVECTOR_DATABASE_URL=

# SQLite-backed vector storage used when VECTOR_STORE_PROVIDER=sqlite
SQLITE_VECTOR_DATABASE_URL=sqlite:///./data/vectors.db

# Development embedding and chunking settings
EMBEDDING_DIMENSION=384
EMBEDDING_PROVIDER=hashing
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_QUERY_INSTRUCTION=Represent this sentence for searching relevant passages: 
EMBEDDING_DEVICE=
EMBEDDING_BATCH_SIZE=32
CHUNK_SIZE=1200
CHUNK_OVERLAP=150

# Retrieval settings
RETRIEVAL_CANDIDATE_LIMIT=30
RETRIEVAL_RERANK_ENABLED=true
RETRIEVAL_LEXICAL_WEIGHT=0.35
RETRIEVAL_DIVERSITY_ENABLED=false
RETRIEVAL_DIVERSITY_LAMBDA=0.75
RETRIEVAL_MIN_SCORE=

# Upload settings
UPLOAD_DIRECTORY=./data/uploads
MAX_UPLOAD_SIZE_MB=25

# OCR settings: disabled or paddle
OCR_PROVIDER=disabled
OCR_LANGUAGE=en
OCR_PDF_DPI=200
